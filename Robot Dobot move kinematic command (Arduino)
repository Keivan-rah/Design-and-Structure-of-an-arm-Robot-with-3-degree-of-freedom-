int colorcheck() 
{
  uint16_t r, g, b, c, colorTemp, lux;
  tcs.getRawData(&r, &g, &b, &c);
  colorTemp = tcs.calculateColorTemperature(r, g, b);
  lux = tcs.calculateLux(r, g, b);
  if ((r>50) && (g>50) && (b>50)){
  if ((r>g) && (g>b)) {digitalWrite(ledr,HIGH);digitalWrite(ledb,LOW);digitalWrite(ledg,LOW);return 1;}
  if ((r>b) && (b>g)) {digitalWrite(ledr,HIGH);digitalWrite(ledb,LOW);digitalWrite(ledg,LOW);return 1;}
  if ((g>b) && (b>r)) {digitalWrite(ledg,HIGH); digitalWrite(ledb,LOW);digitalWrite(ledr,LOW);return 2;}
  if ((g>r) && (r>b)) {digitalWrite(ledg,HIGH); digitalWrite(ledb,LOW);digitalWrite(ledr,LOW);return 2;}
  if ((b>r) && (r>g)) {digitalWrite(ledb,HIGH);digitalWrite(ledr,LOW);digitalWrite(ledg,LOW);return 3;}
  if ((b>g) && (g>r)) {digitalWrite(ledb,HIGH);digitalWrite(ledr,LOW);digitalWrite(ledg,LOW);return 3;}
  }
 
  Serial.print("Color Temp: "); Serial.print(colorTemp, DEC); Serial.print(" K - ");
  Serial.print("Lux: "); Serial.print(lux, DEC); Serial.print(" - ");
  Serial.print("R: "); Serial.print(r, DEC); Serial.print(" ");
  Serial.print("G: "); Serial.print(g, DEC); Serial.print(" ");
  Serial.print("B: "); Serial.print(b, DEC); Serial.print(" ");
  Serial.print("C: "); Serial.print(c, DEC); Serial.print(" ");
  Serial.println(" ");
}
